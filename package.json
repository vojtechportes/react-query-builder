{
  "name": "@vojtechportes/react-query-builder",
  "version": "1.31.1",
  "license": "MIT",
  "description": "Simple, highly configurable query builder for react",
  "keywords": [
    "react",
    "query",
    "builder",
    "query builder",
    "query-builder",
    "react-query-builder",
    "typescript",
    "configurable",
    "query parser",
    "query formatter",
    "sql",
    "mongodb",
    "aql",
    "jsonata",
    "jsonlogic",
    "cel",
    "elasticsearch",
    "prisma",
    "odata",
    "rsql",
    "dynamodb",
    "django"
  ],
  "author": {
    "email": "vojtech.v.portes@gmail.com",
    "name": "Vojtech Portes",
    "url": "https://www.github.com/vojtechportes"
  },
  "homepage": "https://www.react-query-builder.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/vojtechportes/react-query-builder.git"
  },
  "packageManager": "npm@10.9.0",
  "workspaces": [
    "example"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./parseQuery": {
      "types": "./dist/parseQuery.d.ts",
      "import": "./dist/parseQuery.mjs",
      "require": "./dist/parseQuery.cjs"
    },
    "./formatQuery": {
      "types": "./dist/formatQuery.d.ts",
      "import": "./dist/formatQuery.mjs",
      "require": "./dist/formatQuery.cjs"
    },
    "./bootstrap/v5": {
      "types": "./dist/bootstrap/v5/index.d.ts",
      "import": "./dist/bootstrap/v5/index.mjs",
      "require": "./dist/bootstrap/v5/index.cjs"
    },
    "./mui/v7": {
      "types": "./dist/mui/v7/index.d.ts",
      "import": "./dist/mui/v7/index.mjs",
      "require": "./dist/mui/v7/index.cjs"
    },
    "./mui/v9": {
      "types": "./dist/mui/v9/index.d.ts",
      "import": "./dist/mui/v9/index.mjs",
      "require": "./dist/mui/v9/index.cjs"
    },
    "./antd/v5": {
      "types": "./dist/antd/v5/index.d.ts",
      "import": "./dist/antd/v5/index.mjs",
      "require": "./dist/antd/v5/index.cjs"
    },
    "./antd/v6": {
      "types": "./dist/antd/v6/index.d.ts",
      "import": "./dist/antd/v6/index.mjs",
      "require": "./dist/antd/v6/index.cjs"
    },
    "./fluentui/v8": {
      "types": "./dist/fluentui/v8/index.d.ts",
      "import": "./dist/fluentui/v8/index.mjs",
      "require": "./dist/fluentui/v8/index.cjs"
    },
    "./mantine/v8": {
      "types": "./dist/mantine/v8/index.d.ts",
      "import": "./dist/mantine/v8/index.mjs",
      "require": "./dist/mantine/v8/index.cjs"
    },
    "./mantine/v9": {
      "types": "./dist/mantine/v9/index.d.ts",
      "import": "./dist/mantine/v9/index.mjs",
      "require": "./dist/mantine/v9/index.cjs"
    },
    "./radix/v1": {
      "types": "./dist/radix/v1/index.d.ts",
      "import": "./dist/radix/v1/index.mjs",
      "require": "./dist/radix/v1/index.cjs"
    },
    "./monaco": {
      "types": "./dist/monaco/index.d.ts",
      "import": "./dist/monaco/index.mjs",
      "require": "./dist/monaco/index.cjs"
    }
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "files": [
    "dist",
    "!dist/**/*.map",
    "!dist/**/*.d.ts",
    "dist/index.d.ts",
    "dist/parseQuery.d.ts",
    "dist/formatQuery.d.ts",
    "dist/bootstrap/v5/index.d.ts",
    "dist/mui/v7/index.d.ts",
    "dist/mui/v9/index.d.ts",
    "dist/antd/v5/index.d.ts",
    "dist/antd/v6/index.d.ts",
    "dist/fluentui/v8/index.d.ts",
    "dist/mantine/v8/index.d.ts",
    "dist/mantine/v9/index.d.ts",
    "dist/radix/v1/index.d.ts",
    "dist/monaco/index.d.ts"
  ],
  "scripts": {
    "build": "tsdown && node scripts/copy-dts.mjs",
    "dev": "tsdown --watch",
    "test": "jest --runInBand",
    "test:update": "jest --updateSnapshot --runInBand",
    "test:watch": "jest --watch",
    "lint": "eslint .",
    "prettier:check": "prettier --check .",
    "example:dev": "npm run dev --workspace example",
    "example:build": "npm run build --workspace example",
    "check": "npm run lint && npm run test && npm run build && npm run example:build",
    "prepublishOnly": "npm run build"
  },
  "prettier": {
    "printWidth": 80,
    "semi": true,
    "singleQuote": true,
    "trailingComma": "es5"
  },
  "peerDependencies": {
